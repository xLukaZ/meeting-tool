# ── App ──────────────────────────────────────────────────────────────────────
APP_URL="https://yourdomain.com"
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://meetingtool:STRONG_PASSWORD@localhost:5432/meetingtool"

# ── Secrets (generate with: openssl rand -base64 32) ─────────────────────────
SESSION_SECRET="replace-with-output-of-openssl-rand-base64-32"
# Must be EXACTLY 32 characters:
TOKEN_ENCRYPTION_KEY="exactly-32-characters-here!!!!!!"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: https://yourdomain.com/api/team/callback
# Authorized JS origins:    https://yourdomain.com
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxx"
GOOGLE_REDIRECT_URI="https://yourdomain.com/api/team/callback"

# ── Rate limiting (optional) ──────────────────────────────────────────────────
# Leave empty to disable rate limiting (fine for low-traffic installs)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"
